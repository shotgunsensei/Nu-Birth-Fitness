# --- Existing ---
VITE_YOUTUBE_API_KEY=
SESSION_SECRET=replace-with-a-long-random-string

# --- Reset Trap Quiz funnel: API server (artifacts/api-server) ---
ADMIN_PASSWORD=

# Outbound email (optional — without these, emails are logged to the console)
RESEND_API_KEY=
EMAIL_FROM="Nu-Birth Fitness <hello@yourdomain.com>"

# Owner notification + admin links inside emails
OWNER_EMAIL=
PUBLIC_SITE_URL=https://yourdomain.com

# Booking provider URL (Calendly / Cal.com / etc.)
BOOKING_URL=

# Shared secret for inbound /api/webhooks/booking (HMAC-SHA256, hex,
# header: x-booking-signature). When unset, the webhook accepts unauthenticated
# requests and logs a warning — set this for production.
BOOKING_WEBHOOK_SECRET=

# Optional outbound webhook on lead capture (POST JSON)
CRM_WEBHOOK_URL=

# Physical mailing address shown in the email footer (CAN-SPAM compliance).
MAILING_ADDRESS="Nu-Birth Fitness, 123 Example St, City, ST 00000"

# Per-result trainings (YouTube watch URLs are auto-embedded)
RESULT_VIDEO_ALL_OR_NOTHING=
RESULT_VIDEO_STUCK_LOOP=
RESULT_VIDEO_OVERWHELMED=
RESULT_VIDEO_LOST_HERSELF=

# Single video used for /training/:slug ("not ready yet" path)
TRAINING_VIDEO_URL=

# --- Frontend tracking (artifacts/nu-birth-fitness) ---
VITE_GA4_MEASUREMENT_ID=
VITE_META_PIXEL_ID=
